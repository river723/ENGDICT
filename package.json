{
  "name": "kaoyan-english-vocabulary",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "build:web": "expo export:web",
    "electron:dev": "concurrently \"expo start --web\" \"wait-on http://localhost:8081 && electron electron/main.js\"",
    "electron:build": "expo export:web && electron-builder --win"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.0",
    "@expo/webpack-config": "^19.0.1",
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-native-community/cli-server-api": "^20.1.3",
    "@react-navigation/bottom-tabs": "6.5.20",
    "@react-navigation/native": "6.1.9",
    "@react-navigation/stack": "6.3.20",
    "date-fns": "2.30.0",
    "expo": "~55.0.0",
    "expo-dev-client": "^55.0.32",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.22",
    "expo-sharing": "~55.0.20",
    "expo-speech": "^55.0.13",
    "fflate": "^0.8.3",
    "metro": "~0.82.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-native": "^0.85.3",
    "react-native-gesture-handler": "2.14.0",
    "react-native-paper": "5.11.0",
    "react-native-reanimated": "3.6.2",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "3.29.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "~0.21.2"
  },
  "devDependencies": {
    "@babel/core": "7.23.7",
    "@types/react": "19.2.14",
    "@types/react-native": "0.73.0",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "jest": "29.7.0",
    "typescript": "5.3.3",
    "wait-on": "^7.2.0"
  },
  "jest": {
    "preset": "react-native"
  },
  "build": {
    "appId": "com.kaoyan.vocabulary",
    "productName": "考研英语生词本",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "web-build/**/*",
      "electron/**/*",
      "!**/node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "electronDist": "node_modules/electron/dist",
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "考研英语生词本"
    }
  }
}
